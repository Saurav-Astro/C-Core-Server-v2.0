{
  "host": "127.0.0.1",
  "port": 8080,
  "static_dir": "public",
  "log_dir": "../logs",
  "log_file": "server.log",
  "thread_count": 6,
  "max_queue_size": 128,
  "request_timeout_seconds": 5,
  "cache_size": 64,
  "rate_limit_requests": 60,
  "rate_limit_window_seconds": 10,
  "recent_log_limit": 200,
  "max_request_bytes": 16384,
  "backlog": 128,
  "sample_interval_seconds": 1
}
